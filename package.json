{
  "name": "@the-cascade-protocol/sdk",
  "version": "1.3.0",
  "description": "Cascade Protocol SDK - TypeScript library for structured health data",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-cascade-protocol/sdk-typescript.git"
  },
  "homepage": "https://cascadeprotocol.org",
  "bugs": {
    "url": "https://github.com/the-cascade-protocol/sdk-typescript/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cascade-protocol",
    "health-data",
    "rdf",
    "turtle",
    "fhir"
  ],
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
